# ─────────────────────────────────────────────────────────────────────────────
# SvaPro Storefront — Variabili d'Ambiente
#
# Rinomina questo file in ".env.local" e compila i valori reali.
# ATTENZIONE: non committare mai .env.local su Git (è già in .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# URL del tuo sito WooCommerce (senza slash finale)
VITE_WC_URL=https://tuosito.it

# Chiavi API REST generate da WooCommerce
# (WooCommerce > Impostazioni > Avanzate > REST API)
VITE_WC_KEY=ck_inserisci_la_tua_consumer_key
VITE_WC_SECRET=cs_inserisci_il_tuo_consumer_secret
